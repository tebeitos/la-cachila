---
import Layout from '../layouts/Layout.astro';
import { negocio, servicios } from '../data/negocio';

// Schema.org AutoRepair JSON-LD Structured Data
const schemaJSON = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": negocio.nombre,
  "image": "/logo.png",
  "description": `${negocio.eslogan}. Taller mecánico en Gijón con servicio de reparación multimarca, diagnóstico rápido, explicaciones claras de averías y coche de cortesía.`,
  "telephone": `+34${negocio.telefonoLink}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": negocio.direccion,
    "addressLocality": negocio.ciudad,
    "addressRegion": "Asturias",
    "addressCountry": "ES"
  },
  "url": Astro.url.origin,
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
      "opens": "08:00",
      "closes": "15:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Friday"],
      "opens": "08:00",
      "closes": "13:00"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": negocio.rating.replace(',', '.'),
    "reviewCount": negocio.numResenas
  }
};
---

<Layout 
  title="Taller Mecánico en Gijón | Reparación Multimarca | Talleres La Cachila"
  description="Talleres La Cachila es tu taller mecánico de confianza en Gijón. Especialistas en reparación multimarca de vehículos, diagnóstico rápido de averías y coche de cortesía gratis."
>
  <!-- Schema.org Structured Data Injection -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaJSON)} />

  <!-- HEADER / NAVIGATION (Logo left, text next, menu right) -->
  <header class="main-header vintage-border">
    <div class="header-container">
      <div class="logo-area">
        <img src="/logo.png" alt="Logo de Talleres La Cachila" class="logo-img" />
        <div class="logo-text">
          <span class="logo-title">{negocio.nombre}</span>
          <span class="logo-subtitle">{negocio.eslogan}</span>
        </div>
      </div>
      
      <!-- Hamburger Menu Button -->
      <button class="hamburger-menu" id="hamburger-menu-btn" aria-label="Abrir menú" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>

      <nav class="nav-links" id="header-nav-links">
        <a href="#servicios" class="nav-link" id="nav-link-servicios">Servicios</a>
        <a href="#elegirnos" class="nav-link" id="nav-link-elegirnos">Por qué elegirnos</a>
        <a href="#opiniones" class="nav-link" id="nav-link-opiniones">Opiniones</a>
        <a href="#contacto" class="nav-link" id="nav-link-contacto">Contacto</a>
      </nav>
    </div>
  </header>

  <script>
    const hamburger = document.getElementById('hamburger-menu-btn');
    const navLinks = document.getElementById('header-nav-links');

    if (hamburger && navLinks) {
      hamburger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!isExpanded));
        navLinks.classList.toggle('active');
        hamburger.classList.toggle('active');
      });

      // Close menu when clicking a link
      const links = navLinks.querySelectorAll('.nav-link');
      links.forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('active');
          hamburger.setAttribute('aria-expanded', 'false');
          hamburger.classList.remove('active');
        });
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!navLinks.contains(e.target as Node) && !hamburger.contains(e.target as Node)) {
          navLinks.classList.remove('active');
          hamburger.setAttribute('aria-expanded', 'false');
          hamburger.classList.remove('active');
        }
      });
    }
  </script>

  <main>
    <!-- HERO SECTION -->
    <section class="hero-section">
      <div class="hero-container">
        <h1 class="hero-title">Tu coche no es una cachila. Pero si un día lo parece, aquí lo arreglamos.</h1>
        <p class="hero-description">
          Diagnóstico claro, presupuesto sin sorpresas y trato de los de toda la vida. Nada de tecnicismos raros para venderte cosas que no necesitas.
        </p>

        <div class="hero-ctas">
          <a href={`tel:${negocio.telefonoLink}`} class="btn" id="hero-cta-call">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Llamar ahora: {negocio.telefono}
          </a>
          <a href={`https://wa.me/${negocio.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" id="hero-cta-whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            Mensaje WhatsApp
          </a>
        </div>

        <div class="hero-rating-badge vintage-border">
          <span class="stars">★★★★★</span>
          <span class="rating-text"><strong>{negocio.rating} / 5</strong> en Google ({negocio.numResenas} opiniones)</span>
        </div>
      </div>
    </section>

    <!-- SECTION: SERVICIOS -->
    <section id="servicios" class="section-servicios">
      <div class="container">
        <div class="section-header">
          <span class="vintage-badge">Soluciones de Calidad</span>
          <h2>Servicios Profesionales</h2>
          <div class="divider-vintage">
            <div class="divider-vintage-dot"></div>
          </div>
          <p class="section-subtitle">Reparación multimarca en Gijón para todo tipo de vehículos. Cuidado experto y transparente.</p>
        </div>

        <div class="services-grid">
          {servicios.map((servicio, idx) => (
            <div class="service-card vintage-border vintage-shadow" id={`servicio-card-${idx}`}>
              <div class="service-icon-container">
                <span class="service-number">0{idx + 1}</span>
              </div>
              <h3>{servicio.titulo}</h3>
              <p>{servicio.descripcion}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SECTION: POR QUÉ ELEGIRNOS -->
    <section id="elegirnos" class="section-why">
      <div class="container">
        <div class="why-grid">
          <div class="why-image-panel vintage-border vintage-shadow">
            <img src="/logo.png" alt="Ilustración clásica taller La Cachila" class="why-logo-large" />
            <div class="badge-since">
              <span class="badge-since-title">La Cachila</span>
              <span class="badge-since-desc">Compromiso y Garantía</span>
            </div>
          </div>
          
          <div class="why-content">
            <span class="vintage-badge">Nuestros Valores</span>
            <h2>¿Por qué confiar en nosotros?</h2>
            <div class="divider-vintage" style="justify-content: flex-start; margin: 1.5rem 0;">
              <div class="divider-vintage-dot" style="margin-left: 0;"></div>
            </div>
            <p class="why-intro">
              Nos esforzamos por romper con la mala fama de los talleres tradicionales. Queremos que dejes tu coche sabiendo exactamente qué se le va a hacer, cuánto costará y con la tranquilidad de que estás en manos honestas.
            </p>

            <ul class="why-points">
              <li class="why-point-item">
                <div class="point-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                </div>
                <div>
                  <h4>Trato honesto y claro</h4>
                  <p>Te lo contamos como se lo contaríamos a un amigo. Sin palabros raros ni sustos en la factura de última hora.</p>
                </div>
              </li>
              <li class="why-point-item">
                <div class="point-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                </div>
                <div>
                  <h4>Explicamos todo antes de reparar</h4>
                  <p>Antes de tocar nada, te decimos qué tiene y cuánto cuesta. Si luego aparece algo más, te llamamos — no te lo colamos en la factura.</p>
                </div>
              </li>
              <li class="why-point-item">
                <div class="point-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><circle cx="17" cy="17" r="2"></circle><path d="M13 17h2"></path></svg>
                </div>
                <div>
                  <h4>Coche de cortesía gratuito</h4>
                  <p>¿Reparación larga? Te dejamos coche gratis. Que el taller tarde no significa que tu vida tenga que parar.</p>
                </div>
              </li>
              <li class="why-point-item">
                <div class="point-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div>
                  <h4>Rapidez en el diagnóstico</h4>
                  <p>Nada de "vuelva la semana que viene a ver qué le pasa". Le damos caña al diagnóstico y te decimos rápido qué tiene.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION: OPINIONES / RESEÑAS -->
    <section id="opiniones" class="section-reviews">
      <div class="container">
        <div class="section-header">
          <span class="vintage-badge">Lo que dicen (y no lo decimos nosotros)</span>
          <h2>165 personas no pueden estar todas equivocadas</h2>
          <div class="divider-vintage">
            <div class="divider-vintage-dot"></div>
          </div>
          <p class="section-subtitle">Aquí no nos ponemos medallas nosotros solos — que hablen los que ya han pasado por el taller.</p>
        </div>

        <div class="reviews-summary vintage-border">
          <div class="summary-score">
            <span class="score-num">{negocio.rating}</span>
            <div class="summary-stars">
              <span class="stars-gold">★★★★★</span>
              <span class="stars-label">Valoración media en Google</span>
            </div>
          </div>
          <div class="summary-divider"></div>
          <div class="summary-count">
            <span class="count-num">{negocio.numResenas}</span>
            <span class="count-label">Reseñas de clientes reales</span>
          </div>
        </div>

        <div class="reviews-grid">
          <div class="review-card vintage-border vintage-shadow" id="review-card-1">
            <div class="review-stars">★★★★★</div>
            <p class="review-text">
              "Buscaba un taller en Gijón que no me cobrara por cosas que no hacen falta. Me sorprendió gratamente el trato honesto. Me explicaron la avería de forma clara y el presupuesto final coincidió al céntimo. Muy recomendables."
            </p>
            <div class="review-author">
              <span class="author-avatar">C</span>
              <span class="author-name">Cliente de Google Maps</span>
            </div>
          </div>
          <div class="review-card vintage-border vintage-shadow" id="review-card-2">
            <div class="review-stars">★★★★★</div>
            <p class="review-text">
              "Llevé mi coche por un problema eléctrico difícil de diagnosticar. En otros sitios me daban largas, pero aquí dieron con la avería enseguida. Además, me dejaron un coche de cortesía impecable mientras hacían la reparación."
            </p>
            <div class="review-author">
              <span class="author-avatar">M</span>
              <span class="author-name">Cliente de Google Maps</span>
            </div>
          </div>
          <div class="review-card vintage-border vintage-shadow" id="review-card-3">
            <div class="review-stars">★★★★★</div>
            <p class="review-text">
              "Excelente comunicación desde el primer minuto. Me llamaron por teléfono para detallar la pieza rota y el coste antes de iniciar el trabajo. Rapidez en la entrega y precio muy justo. Volveré sin duda."
            </p>
            <div class="review-author">
              <span class="author-avatar">A</span>
              <span class="author-name">Cliente de Google Maps</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION: UBICACIÓN Y CONTACTO -->
    <section id="contacto" class="section-contact">
      <div class="container">
        <div class="section-header">
          <span class="vintage-badge">¿Dónde Estamos?</span>
          <h2>Contacto y Ubicación</h2>
          <div class="divider-vintage">
            <div class="divider-vintage-dot"></div>
          </div>
          <p class="section-subtitle">Visítanos en el centro de Gijón o consúltanos cualquier duda.</p>
        </div>

        <div class="contact-grid">
          <div class="contact-info vintage-border vintage-shadow">
            <h3>Información del Taller</h3>
            <div class="divider-vintage" style="justify-content: flex-start; margin: 1rem 0;">
              <div class="divider-vintage-dot" style="margin-left: 0;"></div>
            </div>
            
            <div class="contact-details">
              <div class="contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <div>
                  <strong>Dirección:</strong>
                  <p>{negocio.direccion}, {negocio.ciudad}</p>
                </div>
              </div>

              <div class="contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <div>
                  <strong>Teléfono:</strong>
                  <p><a href={`tel:${negocio.telefonoLink}`} id="contact-link-phone">{negocio.telefono}</a></p>
                </div>
              </div>

              <div class="contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <div>
                  <strong>Horario de Apertura:</strong>
                  <p class="horario-text">{negocio.horario}</p>
                </div>
              </div>
            </div>

            <div class="contact-actions">
              <a href={`tel:${negocio.telefonoLink}`} class="btn" id="contact-cta-call">Llamar Ahora</a>
              <a href={`https://wa.me/${negocio.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary" id="contact-cta-wa">Escribir por WhatsApp</a>
            </div>
          </div>

          <div class="contact-map-container vintage-border vintage-shadow">
            <iframe
              src="https://maps.google.com/maps?q=C.%20Adaro,%203,%20Gij%C3%B3n&t=&z=16&ie=UTF8&iwloc=&output=embed"
              class="map-iframe"
              allowfullscreen=""
              loading="lazy"
              title="Ubicación de Talleres La Cachila en Gijón"
            ></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="main-footer vintage-border">
    <div class="container footer-container">
      <div class="footer-brand">
        <img src="/logo.png" alt="Logo Talleres La Cachila" class="footer-logo" />
        <div>
          <h3>{negocio.nombre}</h3>
          <p>{negocio.eslogan}</p>
        </div>
      </div>
      
      <div class="footer-links">
        <h4>Información</h4>
        <ul>
          <li><a href="#servicios" id="footer-link-servicios">Servicios</a></li>
          <li><a href="#elegirnos" id="footer-link-elegirnos">Por qué elegirnos</a></li>
          <li><a href="#contacto" id="footer-link-contacto">Contacto y Mapa</a></li>
        </ul>
      </div>

      <div class="footer-legal">
        <h4>Legal</h4>
        <ul>
          <li><a href="/aviso-legal" id="footer-link-aviso">Aviso Legal</a></li>
          <li><a href="/privacidad" id="footer-link-privacidad">Política de Privacidad</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} {negocio.nombre}. Todos los derechos reservados. Mecánica clásica y de confianza en Gijón.</p>
      </div>
    </div>
  </footer>

  <!-- FLOATING WHATSAPP BUTTON -->
  <a 
    href={`https://wa.me/${negocio.whatsapp}`} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="floating-whatsapp-btn" 
    id="floating-whatsapp-btn"
    title="Contactar por WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.717-1.457L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.863-9.73.001-2.595-1.013-5.035-2.857-6.882E-7-1.843-1.847-4.287-2.862-6.883-2.862-5.437 0-9.862 4.369-9.865 9.73-.001 1.705.464 3.37 1.346 4.827l-.995 3.64 3.73-.974zm13.125-6.953c-.3-.15-1.772-.875-2.046-.975-.276-.1-.476-.15-.676.15-.2.3-.775.975-.95 1.175-.175.2-.35.225-.65.075-.3-.15-1.267-.467-2.414-1.492-.893-.797-1.496-1.783-1.672-2.083-.176-.3-.019-.462.13-.61.135-.133.3-.35.45-.525.15-.175.2-.3.3-.5s.05-.375-.025-.525C11.533 7.825 11 6.55 10.774 6c-.221-.527-.443-.454-.606-.462-.156-.008-.335-.01-.515-.01-.18 0-.475.067-.723.338-.249.271-.951.93-.951 2.267 0 1.338.973 2.628 1.109 2.812.137.185 1.916 2.926 4.642 4.103.648.28 1.155.447 1.547.571.653.208 1.248.179 1.718.109.524-.078 1.771-.724 2.021-1.424.25-.699.25-1.3.175-1.425-.075-.125-.275-.2-.575-.35z"/>
    </svg>
  </a>
</Layout>

<style>
  /* ----------------------------------------------------
     PAGES SCROLLPADDING
     ---------------------------------------------------- */
  :global(html) {
    scroll-padding-top: 100px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ----------------------------------------------------
     HEADER & NAVIGATION
     ---------------------------------------------------- */
  .main-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-card);
    border-top: none;
    border-left: none;
    border-right: none;
    padding: 0.75rem 0;
    box-shadow: 0 4px 10px rgba(26, 26, 26, 0.05);
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .logo-area {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-img {
    width: 75px;
    height: 75px;
    border-radius: 50%;
    border: 1.5px solid var(--color-text);
    object-fit: cover;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    line-height: 1.1;
    color: var(--color-primary);
  }

  .logo-subtitle {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  /* Hamburger button styles */
  .hamburger-menu {
    display: none;
    flex-direction: column;
